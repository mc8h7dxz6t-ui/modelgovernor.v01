# Cybersecurity Governor
POSTGRES_DB=cybersecuritygovernor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spine — run: make cg-bootstrap (generates random tokens)
CG_SIDECAR_URL=http://localhost:8101
CG_GATEWAY_URL=http://localhost:8100
CG_INTERNAL_TOKENS=dev-cg-spine-token-change-me
CG_SPINE_ENABLED=true

# Witness quorum (optional demo; auto-enables Object Lock when set)
# SECURITY_ANCHOR_S3_BUCKET=your-corp-security-anchor
# SECURITY_ANCHOR_S3_PREFIX=security-anchors

# Platform defaults
# CG_SPINE_ENABLED=false  # standalone mode — no spine required
