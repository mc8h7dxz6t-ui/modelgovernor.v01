{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FgDecisionChainAnchorWrite",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:PutObjectRetention", "s3:PutObjectLegalHold"],
      "Resource": "arn:aws:s3:::BUCKET_NAME/finance-governor/decision-chain/*"
    },
    {
      "Sid": "FgDecisionChainAnchorRead",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:GetObjectVersion", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::BUCKET_NAME",
        "arn:aws:s3:::BUCKET_NAME/finance-governor/decision-chain/*"
      ]
    }
  ]
}
