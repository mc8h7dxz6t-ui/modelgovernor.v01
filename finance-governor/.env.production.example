# Finance Governor — OIDC issuer URL (Keycloak example)
OIDC_ISSUER_URL=https://keycloak.example.com/realms/finance-governor
OIDC_AUDIENCE=finance-governor
OIDC_ENABLED=true
OIDC_ALLOW_INTERNAL_TOKEN_FALLBACK=false
OIDC_INTERNAL_TOKEN_IS_ADMIN=false

# Production internal token (generate: openssl rand -hex 32)
FG_INTERNAL_TOKEN=
FG_INTERNAL_TOKENS=

# Postgres (Helm in-cluster or external)
POSTGRES_PASSWORD=

# S3 decision chain anchor (create: make fg-aws-anchor-bucket)
DECISION_ANCHOR_S3_BUCKET=
DECISION_ANCHOR_S3_REGION=us-east-1
DECISION_ANCHOR_S3_PREFIX=finance-governor/decision-chain
DECISION_ANCHOR_S3_OBJECT_LOCK_ENABLED=true

# EKS IRSA — annotate ServiceAccount in values-production.yaml:
# serviceAccount.annotations.eks.amazonaws.com/role-arn: arn:aws:iam::ACCOUNT:role/fg-sidecar-anchor
