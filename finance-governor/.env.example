# Finance Governor Spine — local development

POSTGRES_DB=financegovernor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/financegovernor
REDIS_URL=redis://localhost:6380/0

FG_GATEWAY_PORT=8090
FG_SIDECAR_PORT=8091
FG_RECONCILER_PORT=8092
FG_SIDECAR_URL=http://localhost:8091
FG_GATEWAY_URL=http://localhost:8090
FG_SPINE_ENABLED=false
FG_INTERNAL_TOKEN=dev-fg-spine-token-change-me
FG_INTERNAL_TOKENS=dev-fg-spine-token-change-me

# OIDC (optional — Finance Governor native, not ModelGovernor)
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_AUDIENCE=
OIDC_COMMIT_ROLES=fg-commit,financial-admin
OIDC_FINANCIAL_ADMIN_ROLES=financial-admin,fg-admin
OIDC_VIEWER_ROLES=viewer,financial-admin,fg-admin
OIDC_INTERNAL_TOKEN_IS_ADMIN=true

# S3 decision chain anchor (optional)
DECISION_ANCHOR_S3_BUCKET=
DECISION_ANCHOR_S3_PREFIX=finance-governor/decision-chain
DECISION_ANCHOR_S3_OBJECT_LOCK_ENABLED=false

# Integration test Postgres (docker compose -f docker-compose.test.yml)
FG_TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/fg_test

DEFAULT_EXPOSURE_CAP=100000000.000000000000
DRIFT_ABSOLUTE_TOLERANCE=0.500000
DRIFT_RATIO_TOLERANCE=0.050000
FG_OTEL_SERVICE_NAME=financegovernor-sidecar
