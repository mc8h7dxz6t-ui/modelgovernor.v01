# Postgres
POSTGRES_DB=modelgovernor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://localhost:5432/modelgovernor

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Sidecar
SIDECAR_HOST=sidecar
SIDECAR_PORT=8081
SIDECAR_BASE_URL=http://sidecar:8081
SIDECAR_INTERNAL_TOKENS=dev-internal-token
RESERVATION_TTL_SECONDS=300

# Reconciler
RECONCILER_SWEEP_INTERVAL_SECONDS=30

# LiteLLM gateway
LITELLM_MASTER_KEY=dev-litellm-master-key
OPENAI_API_KEY=replace-me
ANTHROPIC_API_KEY=replace-me
