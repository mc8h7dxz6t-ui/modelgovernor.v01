DATABASE_URL=postgresql://postgres:postgres@postgres:5432/modelgovernor
REDIS_URL=redis://redis:6379/0
SIDECAR_INTERNAL_TOKENS=dev-sidecar-token
POSTGRES_DB=modelgovernor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
LITELLM_MASTER_KEY=sk-modelgovernor-dev
# Token the gateway uses when calling the sidecar /reserve and /settle APIs.
# Must match one of the comma-separated values in SIDECAR_INTERNAL_TOKENS.
GATEWAY_TO_SIDECAR_TOKEN=dev-sidecar-token
# Provider API keys — populate only the providers in use for each deployment.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
