DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/modelgovernor
REDIS_URL=redis://redis:6379/0
SIDECAR_INTERNAL_TOKENS=dev-sidecar-token
# Enterprise OIDC (optional — disabled by default)
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://idp.example/realms/modelgovernor
OIDC_AUDIENCE=modelgovernor-sidecar
# OIDC_JWKS_URL=https://idp.example/realms/modelgovernor/protocol/openid-connect/certs
OIDC_VIEWER_ROLES=viewer,modelgovernor-viewer
OIDC_FINANCIAL_ADMIN_ROLES=financial-admin,modelgovernor-financial-admin
OIDC_ALLOW_INTERNAL_TOKEN_FALLBACK=true
# Gateway OIDC (terminates SSO at ingress to /governed/dispatch)
GATEWAY_OIDC_ENABLED=false
GATEWAY_OIDC_ISSUER_URL=https://idp.example/realms/modelgovernor
GATEWAY_OIDC_AUDIENCE=modelgovernor-gateway
GATEWAY_OIDC_DISPATCH_ROLES=dispatch,modelgovernor-dispatch
# S3 Object Lock external ledger anchor (optional)
LEDGER_ANCHOR_S3_BUCKET=
LEDGER_ANCHOR_S3_PREFIX=ledger-anchors
LEDGER_ANCHOR_S3_REGION=us-east-1
LEDGER_ANCHOR_S3_OBJECT_LOCK_ENABLED=false
LEDGER_ANCHOR_S3_OBJECT_LOCK_MODE=GOVERNANCE
LEDGER_ANCHOR_S3_RETENTION_DAYS=3650
DEFAULT_TRACE_CAP_AMOUNT=25.000000
DRIFT_ABSOLUTE_TOLERANCE=0.500000
DRIFT_RATIO_TOLERANCE=0.050000
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT_SECONDS=5
DB_POOL_RECYCLE_SECONDS=1800
POSTGRES_DB=modelgovernor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
LITELLM_MASTER_KEY=sk-modelgovernor-dev
