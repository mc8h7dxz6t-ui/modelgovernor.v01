DATABASE_URL=postgresql://postgres:postgres@postgres:5432/modelgovernor
REDIS_URL=redis://redis:6379/0
SIDECAR_INTERNAL_TOKENS=dev-sidecar-token
DEFAULT_TRACE_CAP_AMOUNT=25.000000
DRIFT_ABSOLUTE_TOLERANCE=0.500000
DRIFT_RATIO_TOLERANCE=0.050000
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT_SECONDS=5
DB_POOL_RECYCLE_SECONDS=1800
ORCHESTRATION_RUNTIME_MODE=coexisting
ORCHESTRATION_SHADOW_MODE=true
ORCHESTRATION_CACHE_TTL_SECONDS=900
POSTGRES_DB=modelgovernor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
LITELLM_MASTER_KEY=sk-modelgovernor-dev
